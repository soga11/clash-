#!/bin/bash
# ===== HY2 + SOCKS5 一键部署 (Debian/Ubuntu systemd) =====
set -e

# ===== 配置（与原脚本保持一致）=====
SOCKS_PORT=40443
SOCKS_USER="soga"
SOCKS_PASS="sogasoga"
HY2_PORT=52015
HY2_PASS="Aq112211!"
HY2_SNI="icloud.cdn-apple.com"

# ===== 检测架构 =====
ARCH=$(uname -m)
case "$ARCH" in
  x86_64) ARCH_SB="amd64"; ARCH_HY="amd64" ;;
  aarch64) ARCH_SB="arm64"; ARCH_HY="arm64" ;;
  *) echo "不支持架构: $ARCH"; exit 1 ;;
esac

# ===== 安装依赖 =====
apt-get update -qq && apt-get install -y -qq curl openssl

# ===== 安装 sing-box =====
echo "[1/4] 安装 sing-box..."
curl -sL --retry 3 -o /tmp/sing-box.tar.gz \
  https://github.com/SagerNet/sing-box/releases/download/v1.13.11/sing-box-1.13.11-linux-${ARCH_SB}.tar.gz
tar -xzf /tmp/sing-box.tar.gz -C /tmp
cp /tmp/sing-box-*/sing-box /usr/local/bin/
rm -rf /tmp/sing-box*

# ===== 安装 hysteria2 =====
echo "[2/4] 安装 hysteria2..."
curl -sL --retry 3 -o /usr/local/bin/hysteria \
  https://github.com/apernet/hysteria/releases/latest/download/hysteria-linux-${ARCH_HY}
chmod +x /usr/local/bin/hysteria

# ===== 生成 TLS 证书 =====
echo "[3/4] 生成证书..."
mkdir -p /root/hy2-cert
openssl ecparam -genkey -name prime256v1 -out /root/hy2-cert/key.pem 2>/dev/null
openssl req -new -x509 -days 3650 -key /root/hy2-cert/key.pem \
  -out /root/hy2-cert/cert.pem -subj "/CN=${HY2_SNI}" 2>/dev/null

# ===== 写入配置 =====
cat > /root/socks.json << EOF
{
  "log": {"level": "info", "timestamp": true, "output": "/var/log/sing-box.log"},
  "inbounds": [{
    "type": "socks", "tag": "socks-in",
    "listen": "0.0.0.0", "listen_port": ${SOCKS_PORT},
    "users": [{"username": "${SOCKS_USER}", "password": "${SOCKS_PASS}"}]
  }],
  "outbounds": [{"type": "direct", "tag": "direct"}]
}
EOF

cat > /root/hy2.yaml << EOF
listen: :${HY2_PORT}
tls:
  cert: /root/hy2-cert/cert.pem
  key: /root/hy2-cert/key.pem
  sni: ${HY2_SNI}
auth:
  type: password
  password: ${HY2_PASS}
masquerade:
  type: proxy
  proxy:
    url: https://${HY2_SNI}
    rewriteHost: true
EOF

# ===== 注册 systemd 服务 =====
echo "[4/4] 注册服务..."
cat > /etc/systemd/system/socks.service << EOF
[Unit]
Description=SOCKS5 Proxy (sing-box)
After=network.target

[Service]
ExecStart=/usr/local/bin/sing-box run -c /root/socks.json
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
EOF

cat > /etc/systemd/system/hy2.service << EOF
[Unit]
Description=Hysteria2 Proxy
After=network.target

[Service]
ExecStart=/usr/local/bin/hysteria server -c /root/hy2.yaml
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable --now socks hy2

# ===== 获取 IP + 输出结果 =====
sleep 2
SERVER_IP=$(curl -s -4 https://api.ipify.org || hostname -I | awk '{print $1}')
HY2_PASS_ENC=$(printf '%s' "$HY2_PASS" | sed 's/!/%21/g')

echo ""
echo "========================================"
echo "  部署完成"
echo "========================================"
echo "SOCKS5 : socks5://${SOCKS_USER}:${SOCKS_PASS}@${SERVER_IP}:${SOCKS_PORT}"
echo "HY2    : hysteria2://${HY2_PASS_ENC}@${SERVER_IP}:${HY2_PORT}?sni=${HY2_SNI}&insecure=1"
echo ""
echo "服务状态:"
systemctl is-active socks hy2
echo ""
echo "常用命令:"
echo "  systemctl status socks / hy2"
echo "  systemctl restart socks / hy2"
echo "  journalctl -u socks -f"
echo "  journalctl -u hy2 -f"
