export DEBIAN_FRONTEND=noninteractive
cat > /root/deploy.sh << 'EOF'
#!/bin/sh
set -e

# ===== 配置 =====
SOCKS_PORT=40443; SOCKS_USER="soga"; SOCKS_PASS="sogasoga"
HY2_PORT=52015;   HY2_PASS="Aq112211!"; HY2_SNI="icloud.cdn-apple.com"

# ===== 架构 =====
case "$(uname -m)" in
  x86_64)  A="amd64" ;;
  aarch64) A="arm64" ;;
  *) echo "不支持架构"; exit 1 ;;
esac

# ===== 安装依赖 =====
if command -v apt-get >/dev/null 2>&1; then
  apt-get update -qq && apt-get install -y -qq curl openssl
elif command -v apk >/dev/null 2>&1; then
  apk add --no-cache curl openssl
elif command -v yum >/dev/null 2>&1; then
  yum install -y -q curl openssl
fi

# ===== 安装 sing-box =====
echo "[1/4] sing-box..."
curl -sL --retry 3 -o /tmp/sb.tar.gz \
  https://github.com/SagerNet/sing-box/releases/download/v1.13.11/sing-box-1.13.11-linux-${A}.tar.gz
tar -xzf /tmp/sb.tar.gz -C /tmp
cp /tmp/sing-box-*/sing-box /usr/local/bin/
rm -rf /tmp/sb.tar.gz /tmp/sing-box-*

# ===== 安装 hysteria2 =====
echo "[2/4] hysteria2..."
curl -sL --retry 3 -o /usr/local/bin/hysteria \
  https://github.com/apernet/hysteria/releases/latest/download/hysteria-linux-${A}
chmod +x /usr/local/bin/hysteria

# ===== 证书 =====
echo "[3/4] 证书..."
mkdir -p /root/hy2-cert
openssl ecparam -genkey -name prime256v1 -out /root/hy2-cert/key.pem 2>/dev/null
openssl req -new -x509 -days 3650 -key /root/hy2-cert/key.pem \
  -out /root/hy2-cert/cert.pem -subj "/CN=${HY2_SNI}" 2>/dev/null

# ===== 配置文件 =====
cat > /root/socks.json << CONF
{"log":{"level":"warn","output":"/var/log/sing-box.log"},"inbounds":[{"type":"socks","listen":"0.0.0.0","listen_port":${SOCKS_PORT},"users":[{"username":"${SOCKS_USER}","password":"${SOCKS_PASS}"}]}],"outbounds":[{"type":"direct"}]}
CONF

cat > /root/hy2.yaml << CONF
listen: :${HY2_PORT}
tls:
  cert: /root/hy2-cert/cert.pem
  key: /root/hy2-cert/key.pem
auth:
  type: password
  password: ${HY2_PASS}
masquerade:
  type: proxy
  proxy:
    url: https://${HY2_SNI}
    rewriteHost: true
CONF

# ===== 注册服务（自动判断 systemd / openrc）=====
echo "[4/4] 服务..."
if command -v systemctl >/dev/null 2>&1 && [ -d /run/systemd ]; then
  # systemd (Debian/Ubuntu/CentOS 7+)
  cat > /etc/systemd/system/socks.service << CONF
[Unit]
Description=SOCKS5
After=network.target
[Service]
ExecStart=/usr/local/bin/sing-box run -c /root/socks.json
Restart=always
[Install]
WantedBy=multi-user.target
CONF
  cat > /etc/systemd/system/hy2.service << CONF
[Unit]
Description=Hysteria2
After=network.target
[Service]
ExecStart=/usr/local/bin/hysteria server -c /root/hy2.yaml
Restart=always
[Install]
WantedBy=multi-user.target
CONF
  systemctl daemon-reload
  systemctl enable --now socks hy2

elif command -v rc-update >/dev/null 2>&1; then
  # OpenRC (Alpine)
  cat > /etc/init.d/socks << CONF
#!/sbin/openrc-run
command="/usr/local/bin/sing-box"
command_args="run -c /root/socks.json"
command_background=true
pidfile="/var/run/socks.pid"
CONF
  cat > /etc/init.d/hy2 << CONF
#!/sbin/openrc-run
command="/usr/local/bin/hysteria"
command_args="server -c /root/hy2.yaml"
command_background=true
pidfile="/var/run/hy2.pid"
CONF
  chmod +x /etc/init.d/socks /etc/init.d/hy2
  rc-update add socks default
  rc-update add hy2 default
  rc-service socks restart
  rc-service hy2 restart

else
  # 兜底：直接后台运行
  nohup /usr/local/bin/sing-box run -c /root/socks.json >> /var/log/sing-box.log 2>&1 &
  nohup /usr/local/bin/hysteria server -c /root/hy2.yaml >> /var/log/hy2.log 2>&1 &
fi

# ===== 输出结果 =====
sleep 2
IP=$(curl -s4 --retry 3 https://api.ipify.org)
PW=$(printf '%s' "$HY2_PASS" | sed 's/!/%21/g')
echo ""
echo "===== 部署完成 ====="
echo "SOCKS5 : socks5://${SOCKS_USER}:${SOCKS_PASS}@${IP}:${SOCKS_PORT}"
echo "HY2    : hysteria2://${PW}@${IP}:${HY2_PORT}?sni=${HY2_SNI}&insecure=1"
ss -tlnup | grep -E "${SOCKS_PORT}|${HY2_PORT}" || true
EOF

bash /root/deploy.sh
