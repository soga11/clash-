#!/bin/bash
set -e

VERSION="S-UI_v1.4.1"
BASE_URL="https://github.com/soga11/clash-/releases/download/${VERSION}"
INSTALL_DIR="/usr/local/s-ui"
SERVICE_NAME="s-ui"

PANEL_PORT="2095"
SUB_PORT="2096"
PANEL_PATH="/app/login"

echo "========================================"
echo "开始安装 S-UI"
echo "版本: ${VERSION}"
echo "========================================"

if [ "$(id -u)" != "0" ]; then
    echo "请使用 root 用户运行此脚本"
    echo "例如：sudo bash install.sh"
    exit 1
fi

echo "安装基础依赖..."

if command -v apt >/dev/null 2>&1; then
    apt update -y
    apt install -y wget curl tar ca-certificates
elif command -v yum >/dev/null 2>&1; then
    yum install -y wget curl tar ca-certificates
elif command -v dnf >/dev/null 2>&1; then
    dnf install -y wget curl tar ca-certificates
else
    echo "未检测到 apt/yum/dnf，请确认系统已安装 wget/curl/tar"
fi

if ! command -v systemctl >/dev/null 2>&1; then
    echo "当前系统不支持 systemctl，暂不支持安装"
    exit 1
fi

ARCH=$(uname -m)

case "$ARCH" in
    x86_64|amd64)
        FILE="s-ui-linux-amd64.tar.gz"
        ;;
    aarch64|arm64)
        FILE="s-ui-linux-arm64.tar.gz"
        ;;
    *)
        echo "不支持的系统架构: $ARCH"
        exit 1
        ;;
esac

URL="${BASE_URL}/${FILE}"

echo "检测到系统架构: $ARCH"
echo "准备下载文件: $FILE"
echo "下载地址: $URL"

echo "停止旧服务..."
systemctl stop ${SERVICE_NAME} 2>/dev/null || true

if [ -d "$INSTALL_DIR" ]; then
    BACKUP_DIR="${INSTALL_DIR}.bak.$(date +%F-%H%M%S)"
    echo "备份旧版本到: $BACKUP_DIR"
    cp -a "$INSTALL_DIR" "$BACKUP_DIR"
fi

echo "清理旧目录..."
rm -rf "$INSTALL_DIR"
mkdir -p "$INSTALL_DIR"

TMP_DIR=$(mktemp -d)
cd "$TMP_DIR"

echo "开始下载..."

if command -v wget >/dev/null 2>&1; then
    wget -O "$FILE" "$URL"
else
    curl -L --fail -o "$FILE" "$URL"
fi

if [ ! -s "$FILE" ]; then
    echo "下载失败，文件为空"
    rm -rf "$TMP_DIR"
    exit 1
fi

echo "下载完成，文件大小："
ls -lh "$FILE"

echo "开始解压..."
tar -xzf "$FILE" -C "$INSTALL_DIR"

echo "查找 sui 可执行文件..."

SUI_BIN=$(find "$INSTALL_DIR" -type f -name "sui" | head -n 1)

if [ -z "$SUI_BIN" ]; then
    echo "未找到 sui 文件，尝试查找可执行文件..."
    SUI_BIN=$(find "$INSTALL_DIR" -type f -perm /111 | head -n 1)
fi

if [ -z "$SUI_BIN" ]; then
    echo "未找到 sui 可执行文件，请检查压缩包结构"
    echo "当前解压文件列表："
    find "$INSTALL_DIR" -maxdepth 4 -type f
    rm -rf "$TMP_DIR"
    exit 1
fi

SUI_DIR=$(dirname "$SUI_BIN")

chmod +x "$SUI_BIN"

echo "检测到运行目录: $SUI_DIR"
echo "检测到运行文件: $SUI_BIN"

if [ -f "$SUI_DIR/s-ui.sh" ]; then
    chmod +x "$SUI_DIR/s-ui.sh"
    ln -sf "$SUI_DIR/s-ui.sh" /usr/bin/s-ui
fi

echo "写入 systemd 服务..."

cat > /etc/systemd/system/${SERVICE_NAME}.service <<EOF
[Unit]
Description=S-UI Service
After=network.target nss-lookup.target

[Service]
Type=simple
User=root
WorkingDirectory=${SUI_DIR}
ExecStart=${SUI_BIN}
Restart=on-failure
RestartSec=5
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
EOF

echo "尝试放行防火墙端口 ${PANEL_PORT} 和 ${SUB_PORT}..."

if command -v ufw >/dev/null 2>&1; then
    ufw allow ${PANEL_PORT}/tcp >/dev/null 2>&1 || true
    ufw allow ${SUB_PORT}/tcp >/dev/null 2>&1 || true
fi

if command -v firewall-cmd >/dev/null 2>&1; then
    firewall-cmd --permanent --add-port=${PANEL_PORT}/tcp >/dev/null 2>&1 || true
    firewall-cmd --permanent --add-port=${SUB_PORT}/tcp >/dev/null 2>&1 || true
    firewall-cmd --reload >/dev/null 2>&1 || true
fi

if command -v iptables >/dev/null 2>&1; then
    iptables -C INPUT -p tcp --dport ${PANEL_PORT} -j ACCEPT >/dev/null 2>&1 || \
    iptables -I INPUT -p tcp --dport ${PANEL_PORT} -j ACCEPT >/dev/null 2>&1 || true

    iptables -C INPUT -p tcp --dport ${SUB_PORT} -j ACCEPT >/dev/null 2>&1 || \
    iptables -I INPUT -p tcp --dport ${SUB_PORT} -j ACCEPT >/dev/null 2>&1 || true
fi

echo "启动 S-UI 服务..."

systemctl daemon-reload
systemctl enable ${SERVICE_NAME} >/dev/null 2>&1
systemctl restart ${SERVICE_NAME}

sleep 2

if systemctl is-active --quiet ${SERVICE_NAME}; then
    echo "S-UI 服务启动成功"
else
    echo "S-UI 服务启动失败，最近日志如下："
    journalctl -u ${SERVICE_NAME} -n 80 --no-pager
    rm -rf "$TMP_DIR"
    exit 1
fi

rm -rf "$TMP_DIR"

get_ipv4() {
    IP=$(curl -4s --max-time 5 https://api.ipify.org 2>/dev/null || true)
    if echo "$IP" | grep -Eq '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$'; then
        echo "$IP"
        return
    fi

    IP=$(curl -4s --max-time 5 https://checkip.amazonaws.com 2>/dev/null | tr -d '\n\r' || true)
    if echo "$IP" | grep -Eq '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$'; then
        echo "$IP"
        return
    fi

    hostname -I 2>/dev/null | awk '{print $1}'
}

get_ipv6() {
    IP=$(curl -6s --max-time 5 https://api64.ipify.org 2>/dev/null || true)
    if echo "$IP" | grep -q ':'; then
        echo "$IP"
        return
    fi

    ip -6 addr show scope global 2>/dev/null | grep inet6 | awk '{print $2}' | cut -d/ -f1 | grep -v '^fd' | grep -v '^fe80' | head -n 1
}

IPV4=$(get_ipv4 || true)
IPV6=$(get_ipv6 || true)

echo ""
echo "========================================"
echo "S-UI 安装完成"
echo "========================================"
echo "版本: ${VERSION}"
echo "安装目录: ${INSTALL_DIR}"
echo "运行目录: ${SUI_DIR}"
echo "运行文件: ${SUI_BIN}"
echo ""

if [ -n "$IPV4" ]; then
    echo "面板地址：http://${IPV4}:${PANEL_PORT}${PANEL_PATH}"
    echo "IPv4 面板地址: http://${IPV4}:${PANEL_PORT}${PANEL_PATH}"
else
    echo "面板地址：未检测到 IPv4"
    echo "IPv4 面板地址: 未检测到"
fi

if [ -n "$IPV6" ]; then
    echo "IPv6 面板地址: http://[${IPV6}]:${PANEL_PORT}${PANEL_PATH}"
else
    echo "IPv6 面板地址: 未检测到"
fi

echo ""
echo "默认账号：admin"
echo "默认密码：admin"
echo "安全提示：登录后请立即修改默认账号和密码"
echo ""
echo "面板端口: ${PANEL_PORT}"
echo "订阅端口: ${SUB_PORT}"
echo ""
echo "常用命令："
echo "启动: systemctl start s-ui"
echo "停止: systemctl stop s-ui"
echo "重启: systemctl restart s-ui"
echo "状态: systemctl status s-ui"
echo "日志: journalctl -u s-ui -f"
echo ""
echo "如果无法访问，请检查 AWS 安全组是否放行："
echo "TCP ${PANEL_PORT}"
echo "TCP ${SUB_PORT}"
echo "========================================"
echo ""

systemctl status ${SERVICE_NAME} --no-pager
