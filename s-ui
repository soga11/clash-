#!/usr/bin/env bash

set -e

VERSION="S-UI_v1.4.1"

REPO_RELEASE_BASE="https://github.com/soga11/clash-/releases/download/${VERSION}"

PANEL_PORT="2095"
PANEL_PATH="/app/login"
PANEL_USER="admin"
PANEL_PASS="admin"

SERVICE_NAME="s-ui"
INSTALL_DIR="/usr/local/s-ui"
BIN_PATH="${INSTALL_DIR}/s-ui"

GREEN="\033[0;32m"
YELLOW="\033[0;33m"
RED="\033[0;31m"
PLAIN="\033[0m"

info() {
    echo -e "${GREEN}[信息]${PLAIN} $1"
}

warn() {
    echo -e "${YELLOW}[警告]${PLAIN} $1"
}

error() {
    echo -e "${RED}[错误]${PLAIN} $1"
}

check_root() {
    if [[ $EUID -ne 0 ]]; then
        error "请使用 root 用户运行"
        exit 1
    fi
}

install_base() {
    info "正在安装基础依赖..."

    if command -v apt >/dev/null 2>&1; then
        apt update -y
        apt install -y curl wget tar unzip ca-certificates systemd
    elif command -v yum >/dev/null 2>&1; then
        yum install -y curl wget tar unzip ca-certificates
    elif command -v dnf >/dev/null 2>&1; then
        dnf install -y curl wget tar unzip ca-certificates
    else
        warn "未识别到 apt/yum/dnf，请确认系统已安装 curl wget tar unzip"
    fi
}

detect_arch() {
    local arch
    arch=$(uname -m)

    case "$arch" in
        x86_64|amd64)
            echo "amd64"
            ;;
        aarch64|arm64)
            echo "arm64"
            ;;
        *)
            error "不支持的系统架构: $arch"
            exit 1
            ;;
    esac
}

stop_old_service() {
    info "停止旧服务，如果存在..."

    systemctl stop ${SERVICE_NAME} >/dev/null 2>&1 || true
}

backup_old_install() {
    if [[ -d "$INSTALL_DIR" ]]; then
        local backup_dir
        backup_dir="/usr/local/s-ui-backup-$(date +%Y%m%d%H%M%S)"
        info "检测到旧安装目录，备份到: ${backup_dir}"
        cp -a "$INSTALL_DIR" "$backup_dir" || true
    fi
}

download_and_install() {
    local arch
    local url
    local tmp_dir
    local package_file
    local found_bin

    arch=$(detect_arch)

    if [[ "$arch" == "amd64" ]]; then
        url="${REPO_RELEASE_BASE}/s-ui-linux-amd64.tar.gz"
    elif [[ "$arch" == "arm64" ]]; then
        url="${REPO_RELEASE_BASE}/s-ui-linux-arm64.tar.gz"
    fi

    info "当前系统架构: ${arch}"
    info "下载地址: ${url}"

    tmp_dir=$(mktemp -d)
    package_file="${tmp_dir}/s-ui.tar.gz"

    curl -L --fail --connect-timeout 15 --max-time 300 -o "$package_file" "$url"

    info "正在解压安装包..."

    mkdir -p "$tmp_dir/extract"
    tar -zxf "$package_file" -C "$tmp_dir/extract"

    mkdir -p "$INSTALL_DIR"

    found_bin=$(find "$tmp_dir/extract" -type f \( -name "s-ui" -o -name "s-ui-linux-amd64" -o -name "s-ui-linux-arm64" \) | head -n 1)

    if [[ -z "$found_bin" ]]; then
        warn "没有找到明确的 s-ui 二进制文件，尝试查找可执行文件..."
        found_bin=$(find "$tmp_dir/extract" -type f -perm /111 | head -n 1)
    fi

    if [[ -z "$found_bin" ]]; then
        error "安装失败：压缩包里没有找到可执行文件"
        echo "解压内容如下："
        find "$tmp_dir/extract" -maxdepth 3 -type f
        exit 1
    fi

    info "找到程序文件: ${found_bin}"

    cp -f "$found_bin" "$BIN_PATH"
    chmod +x "$BIN_PATH"

    # 如果压缩包里还有其他文件，一并复制过去，避免缺少静态资源
    cp -a "$tmp_dir/extract"/. "$INSTALL_DIR"/ || true
    chmod +x "$BIN_PATH"

    rm -rf "$tmp_dir"

    info "S-UI 已安装到: ${BIN_PATH}"
}

create_systemd_service() {
    info "正在创建 systemd 服务..."

    cat > "/etc/systemd/system/${SERVICE_NAME}.service" <<EOF
[Unit]
Description=S-UI Service
After=network.target nss-lookup.target

[Service]
Type=simple
User=root
WorkingDirectory=${INSTALL_DIR}
ExecStart=${BIN_PATH}
Restart=on-failure
RestartSec=5s
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
EOF

    systemctl daemon-reload
    systemctl enable ${SERVICE_NAME} >/dev/null 2>&1
}

open_firewall_port() {
    info "尝试放行面板端口 ${PANEL_PORT}..."

    if command -v ufw >/dev/null 2>&1; then
        ufw allow ${PANEL_PORT}/tcp >/dev/null 2>&1 || true
    fi

    if command -v firewall-cmd >/dev/null 2>&1; then
        firewall-cmd --permanent --add-port=${PANEL_PORT}/tcp >/dev/null 2>&1 || true
        firewall-cmd --reload >/dev/null 2>&1 || true
    fi

    if command -v iptables >/dev/null 2>&1; then
        iptables -C INPUT -p tcp --dport ${PANEL_PORT} -j ACCEPT >/dev/null 2>&1 || \
        iptables -I INPUT -p tcp --dport ${PANEL_PORT} -j ACCEPT >/dev/null 2>&1 || true
    fi
}

start_service() {
    info "正在启动 S-UI 服务..."

    systemctl restart ${SERVICE_NAME}

    sleep 2

    if systemctl is-active --quiet ${SERVICE_NAME}; then
        info "S-UI 服务启动成功"
    else
        error "S-UI 服务启动失败，最近日志如下："
        journalctl -u ${SERVICE_NAME} -n 50 --no-pager
        exit 1
    fi
}

get_public_ipv4() {
    local ip=""

    ip=$(curl -4s --max-time 5 https://api.ipify.org 2>/dev/null | tr -d '\n\r')
    if [[ -n "$ip" && "$ip" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        echo "$ip"
        return
    fi

    ip=$(curl -4s --max-time 5 https://ipv4.icanhazip.com 2>/dev/null | tr -d '\n\r')
    if [[ -n "$ip" && "$ip" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        echo "$ip"
        return
    fi

    ip=$(curl -4s --max-time 5 https://checkip.amazonaws.com 2>/dev/null | tr -d '\n\r')
    if [[ -n "$ip" && "$ip" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        echo "$ip"
        return
    fi

    ip=$(hostname -I 2>/dev/null | awk '{print $1}')
    if [[ -n "$ip" && "$ip" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        echo "$ip"
    fi
}

get_public_ipv6() {
    local ip=""

    ip=$(curl -6s --max-time 5 https://api64.ipify.org 2>/dev/null | tr -d '\n\r')
    if [[ -n "$ip" && "$ip" == *:* ]]; then
        echo "$ip"
        return
    fi

    ip=$(curl -6s --max-time 5 https://ipv6.icanhazip.com 2>/dev/null | tr -d '\n\r')
    if [[ -n "$ip" && "$ip" == *:* ]]; then
        echo "$ip"
        return
    fi

    ip=$(curl -6s --max-time 5 https://ifconfig.co 2>/dev/null | tr -d '\n\r')
    if [[ -n "$ip" && "$ip" == *:* ]]; then
        echo "$ip"
        return
    fi

    ip=$(ip -6 addr show scope global 2>/dev/null | grep inet6 | awk '{print $2}' | cut -d/ -f1 | grep -v '^fd' | grep -v '^fe80' | head -n 1)
    if [[ -n "$ip" && "$ip" == *:* ]]; then
        echo "$ip"
    fi
}

show_result() {
    local IPV4=""
    local IPV6=""

    IPV4=$(get_public_ipv4 || true)
    IPV6=$(get_public_ipv6 || true)

    echo ""
    echo "========================================"
    echo "S-UI 安装完成"
    echo "========================================"

    if [[ -n "$IPV4" ]]; then
        echo "IPv4 面板地址: http://${IPV4}:${PANEL_PORT}${PANEL_PATH}"
    else
        echo "IPv4 面板地址: 未检测到"
    fi

    if [[ -n "$IPV6" ]]; then
        echo "IPv6 面板地址: http://[${IPV6}]:${PANEL_PORT}${PANEL_PATH}"
    else
        echo "IPv6 面板地址: 未检测到"
    fi

    echo ""
    echo "端口: ${PANEL_PORT}"
    echo "账号: ${PANEL_USER}"
    echo "密码: ${PANEL_PASS}"
    echo ""
    echo "安装目录: ${INSTALL_DIR}"
    echo "程序路径: ${BIN_PATH}"
    echo ""
    echo "常用命令:"
    echo "启动: systemctl start ${SERVICE_NAME}"
    echo "停止: systemctl stop ${SERVICE_NAME}"
    echo "重启: systemctl restart ${SERVICE_NAME}"
    echo "状态: systemctl status ${SERVICE_NAME}"
    echo "日志: journalctl -u ${SERVICE_NAME} -f"
    echo ""
    echo "如果无法访问，请检查："
    echo "1. AWS 安全组是否放行 TCP ${PANEL_PORT}"
    echo "2. Ubuntu 防火墙是否放行 TCP ${PANEL_PORT}"
    echo "3. 服务是否正常运行：systemctl status ${SERVICE_NAME}"
    echo "========================================"
    echo ""
}

main() {
    check_root
    install_base
    stop_old_service
    backup_old_install
    download_and_install
    create_systemd_service
    open_firewall_port
    start_service
    show_result
}

main
