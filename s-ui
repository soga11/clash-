#!/usr/bin/env bash

set -e

PANEL_PORT="2095"
PANEL_PATH="/app/login"
PANEL_USER="admin"
PANEL_PASS="admin"

SERVICE_NAME="s-ui"

GREEN="\033[0;32m"
YELLOW="\033[0;33m"
RED="\033[0;31m"
PLAIN="\033[0m"

info() {
    echo -e "${GREEN}[信息]${PLAIN} $1"
}

warn() {
    echo -e "${YELLOW}[警告]${PLAIN} $1"
}

error() {
    echo -e "${RED}[错误]${PLAIN} $1"
}

check_root() {
    if [[ $EUID -ne 0 ]]; then
        error "请使用 root 用户运行"
        exit 1
    fi
}

install_base() {
    info "正在安装基础依赖..."

    if command -v apt >/dev/null 2>&1; then
        apt update -y
        apt install -y curl wget tar unzip ca-certificates
    elif command -v yum >/dev/null 2>&1; then
        yum install -y curl wget tar unzip ca-certificates
    elif command -v dnf >/dev/null 2>&1; then
        dnf install -y curl wget tar unzip ca-certificates
    else
        warn "未识别到 apt/yum/dnf，请确认系统已安装 curl wget tar unzip"
    fi
}

run_official_install() {
    info "正在执行 S-UI 官方安装脚本..."

    bash <(curl -Ls https://raw.githubusercontent.com/alireza0/s-ui/master/install.sh)
}

open_firewall_port() {
    info "尝试放行面板端口 ${PANEL_PORT}..."

    if command -v ufw >/dev/null 2>&1; then
        ufw allow ${PANEL_PORT}/tcp >/dev/null 2>&1 || true
    fi

    if command -v firewall-cmd >/dev/null 2>&1; then
        firewall-cmd --permanent --add-port=${PANEL_PORT}/tcp >/dev/null 2>&1 || true
        firewall-cmd --reload >/dev/null 2>&1 || true
    fi

    if command -v iptables >/dev/null 2>&1; then
        iptables -C INPUT -p tcp --dport ${PANEL_PORT} -j ACCEPT >/dev/null 2>&1 || \
        iptables -I INPUT -p tcp --dport ${PANEL_PORT} -j ACCEPT >/dev/null 2>&1 || true
    fi
}

get_public_ipv4() {
    local ip=""

    ip=$(curl -4s --max-time 5 https://api.ipify.org 2>/dev/null | tr -d '\n\r')
    if [[ -n "$ip" && "$ip" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        echo "$ip"
        return
    fi

    ip=$(curl -4s --max-time 5 https://ipv4.icanhazip.com 2>/dev/null | tr -d '\n\r')
    if [[ -n "$ip" && "$ip" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        echo "$ip"
        return
    fi

    ip=$(curl -4s --max-time 5 https://checkip.amazonaws.com 2>/dev/null | tr -d '\n\r')
    if [[ -n "$ip" && "$ip" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        echo "$ip"
        return
    fi

    ip=$(curl -4s --max-time 5 https://ifconfig.me 2>/dev/null | tr -d '\n\r')
    if [[ -n "$ip" && "$ip" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        echo "$ip"
        return
    fi

    ip=$(hostname -I 2>/dev/null | awk '{print $1}')
    if [[ -n "$ip" && "$ip" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        echo "$ip"
    fi
}

get_public_ipv6() {
    local ip=""

    ip=$(curl -6s --max-time 5 https://api64.ipify.org 2>/dev/null | tr -d '\n\r')
    if [[ -n "$ip" && "$ip" == *:* ]]; then
        echo "$ip"
        return
    fi

    ip=$(curl -6s --max-time 5 https://ipv6.icanhazip.com 2>/dev/null | tr -d '\n\r')
    if [[ -n "$ip" && "$ip" == *:* ]]; then
        echo "$ip"
        return
    fi

    ip=$(curl -6s --max-time 5 https://ifconfig.co 2>/dev/null | tr -d '\n\r')
    if [[ -n "$ip" && "$ip" == *:* ]]; then
        echo "$ip"
        return
    fi

    ip=$(ip -6 addr show scope global 2>/dev/null | grep inet6 | awk '{print $2}' | cut -d/ -f1 | grep -v '^fd' | grep -v '^fe80' | head -n 1)
    if [[ -n "$ip" && "$ip" == *:* ]]; then
        echo "$ip"
    fi
}

restart_service() {
    info "尝试重启 S-UI 服务..."

    systemctl daemon-reload >/dev/null 2>&1 || true

    if systemctl list-unit-files | grep -q "^${SERVICE_NAME}.service"; then
        systemctl enable ${SERVICE_NAME} >/dev/null 2>&1 || true
        systemctl restart ${SERVICE_NAME} >/dev/null 2>&1 || true
    fi
}

show_result() {
    local IPV4=""
    local IPV6=""

    IPV4=$(get_public_ipv4 || true)
    IPV6=$(get_public_ipv6 || true)

    echo ""
    echo "========================================"
    echo "S-UI 安装完成"
    echo "========================================"

    if [[ -n "$IPV4" ]]; then
        echo "IPv4 面板地址: http://${IPV4}:${PANEL_PORT}${PANEL_PATH}"
    else
        echo "IPv4 面板地址: 未检测到"
    fi

    if [[ -n "$IPV6" ]]; then
        echo "IPv6 面板地址: http://[${IPV6}]:${PANEL_PORT}${PANEL_PATH}"
    else
        echo "IPv6 面板地址: 未检测到"
    fi

    echo ""
    echo "端口: ${PANEL_PORT}"
    echo "账号: ${PANEL_USER}"
    echo "密码: ${PANEL_PASS}"
    echo ""
    echo "常用命令:"
    echo "启动: systemctl start ${SERVICE_NAME}"
    echo "停止: systemctl stop ${SERVICE_NAME}"
    echo "重启: systemctl restart ${SERVICE_NAME}"
    echo "状态: systemctl status ${SERVICE_NAME}"
    echo "日志: journalctl -u ${SERVICE_NAME} -f"
    echo ""
    echo "如果无法访问，请检查："
    echo "1. 云服务器安全组是否放行 TCP ${PANEL_PORT}"
    echo "2. 系统防火墙是否放行 TCP ${PANEL_PORT}"
    echo "3. IPv6 访问需要安全组放行 IPv6 入站规则"
    echo "========================================"
    echo ""
}

main() {
    check_root
    install_base
    run_official_install
    open_firewall_port
    restart_service
    show_result
}

main
