#!/bin/bash
set -e

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo -e "${GREEN}========================================${NC}"
echo -e "${GREEN}   HY2 + SOCKS5 一键安装（无交互）${NC}"
echo -e "${GREEN}========================================${NC}"

# 固定参数
HY2_PORT="52015"
HY2_PASSWORD="Aq112211!"
SNI_DOMAIN="icloud.cdn-apple.com"

SOCKS_PORT="40443"
SOCKS_USER="soga"
SOCKS_PASS="sogasoga"

INSTALL_DIR="/opt/sing-box"
CERT_DIR="${INSTALL_DIR}/cert"
CONFIG_FILE="${INSTALL_DIR}/config.json"
SERVICE_FILE="/etc/systemd/system/sing-box.service"

# root 检查
if [ "$(id -u)" != "0" ]; then
  echo -e "${RED}[错误] 请使用 root 运行此脚本${NC}"
  exit 1
fi

# 架构检测
ARCH_RAW="$(uname -m)"
case "$ARCH_RAW" in
  x86_64) ARCH="amd64" ;;
  aarch64|arm64) ARCH="arm64" ;;
  armv7l) ARCH="armv7" ;;
  *)
    echo -e "${RED}[错误] 不支持的架构: ${ARCH_RAW}${NC}"
    exit 1
    ;;
esac

install_deps() {
  echo -e "${GREEN}[信息] 安装依赖中...${NC}"
  if command -v apt-get >/dev/null 2>&1; then
    apt-get update
    apt-get install -y curl wget jq tar gzip openssl ca-certificates
  elif command -v dnf >/dev/null 2>&1; then
    dnf install -y curl wget jq tar gzip openssl ca-certificates
  elif command -v yum >/dev/null 2>&1; then
    yum install -y curl wget jq tar gzip openssl ca-certificates
  elif command -v apk >/dev/null 2>&1; then
    apk add --no-cache curl wget jq tar gzip openssl ca-certificates
  else
    echo -e "${RED}[错误] 未识别的包管理器，请手动安装 curl/wget/jq/tar/openssl${NC}"
    exit 1
  fi
}

for cmd in curl wget jq tar openssl; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    install_deps
    break
  fi
done

detect_ip() {
  SERVER_IP="$(curl -4 -s --max-time 8 https://api.ipify.org || true)"
  if [ -z "$SERVER_IP" ]; then
    SERVER_IP="$(curl -4 -s --max-time 8 https://ipv4.icanhazip.com | tr -d '\n' || true)"
  fi
  if [ -z "$SERVER_IP" ]; then
    SERVER_IP="$(curl -4 -s --max-time 8 https://ifconfig.me || true)"
  fi
  if [ -z "$SERVER_IP" ]; then
    echo -e "${RED}[错误] 自动检测公网 IP 失败${NC}"
    exit 1
  fi
  echo -e "${GREEN}[信息] 检测到服务器 IP: ${SERVER_IP}${NC}"
}

install_or_update_singbox() {
  echo -e "${GREEN}[信息] 获取 sing-box 最新版本...${NC}"
  VERSION="$(curl -s https://api.github.com/repos/SagerNet/sing-box/releases/latest | jq -r .tag_name)"

  if [ -z "$VERSION" ] || [ "$VERSION" = "null" ]; then
    echo -e "${RED}[错误] 获取 sing-box 最新版本失败${NC}"
    exit 1
  fi

  mkdir -p /tmp/sing-box-install
  cd /tmp/sing-box-install

  FILE="sing-box-${VERSION#v}-linux-${ARCH}.tar.gz"
  URL="https://github.com/SagerNet/sing-box/releases/download/${VERSION}/${FILE}"

  echo -e "${GREEN}[信息] 下载 ${VERSION} ...${NC}"
  wget -O "${FILE}" "$URL"

  tar -xzf "${FILE}"
  BIN_PATH="$(find . -type f -name sing-box | head -n 1)"

  if [ -z "$BIN_PATH" ]; then
    echo -e "${RED}[错误] sing-box 可执行文件未找到${NC}"
    exit 1
  fi

  install -m 755 "$BIN_PATH" /usr/local/bin/sing-box
  mkdir -p "${INSTALL_DIR}"

  echo -e "${GREEN}[成功] sing-box 已安装/更新到: ${VERSION}${NC}"
}

generate_cert() {
  mkdir -p "${CERT_DIR}"

  if [ ! -f "${CERT_DIR}/cert.pem" ] || [ ! -f "${CERT_DIR}/key.pem" ]; then
    echo -e "${GREEN}[信息] 生成自签证书...${NC}"
    openssl req -x509 -newkey rsa:2048 -nodes \
      -keyout "${CERT_DIR}/key.pem" \
      -out "${CERT_DIR}/cert.pem" \
      -days 3650 \
      -subj "/C=US/ST=California/L=Cupertino/O=Apple Inc./OU=Apple CDN/CN=${SNI_DOMAIN}" >/dev/null 2>&1
  else
    echo -e "${YELLOW}[信息] 证书已存在，跳过生成${NC}"
  fi
}

write_config() {
  mkdir -p "${INSTALL_DIR}"

  cat > "${CONFIG_FILE}" <<EOF
{
  "log": {
    "level": "info"
  },
  "inbounds": [
    {
      "type": "hysteria2",
      "tag": "hy2-in",
      "listen": "::",
      "listen_port": ${HY2_PORT},
      "users": [
        {
          "password": "${HY2_PASSWORD}"
        }
      ],
      "tls": {
        "enabled": true,
        "certificate_path": "${CERT_DIR}/cert.pem",
        "key_path": "${CERT_DIR}/key.pem"
      },
      "masquerade": "https://www.apple.com"
    },
    {
      "type": "socks",
      "tag": "socks-in",
      "listen": "0.0.0.0",
      "listen_port": ${SOCKS_PORT},
      "users": [
        {
          "username": "${SOCKS_USER}",
          "password": "${SOCKS_PASS}"
        }
      ]
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    }
  ]
}
EOF

  echo -e "${GREEN}[成功] 配置已写入: ${CONFIG_FILE}${NC}"
}

write_service() {
  cat > "${SERVICE_FILE}" <<EOF
[Unit]
Description=sing-box service
After=network.target nss-lookup.target

[Service]
Type=simple
ExecStart=/usr/local/bin/sing-box run -c ${CONFIG_FILE}
Restart=always
RestartSec=3
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
EOF

  systemctl daemon-reload
  systemctl enable sing-box >/dev/null 2>&1
  systemctl restart sing-box
}

check_service() {
  sleep 2
  if systemctl is-active --quiet sing-box; then
    echo -e "${GREEN}[成功] sing-box 服务已启动${NC}"
  else
    echo -e "${RED}[错误] sing-box 启动失败，日志如下：${NC}"
    journalctl -u sing-box -n 50 --no-pager
    exit 1
  fi
}

print_result() {
  cat <<EOF

========================================
安装完成
========================================

服务器 IP: ${SERVER_IP}

[HY2 信息]
端口: ${HY2_PORT}
密码: ${HY2_PASSWORD}
SNI: ${SNI_DOMAIN}

HY2 链接:
hysteria2://${HY2_PASSWORD}@${SERVER_IP}:${HY2_PORT}/?insecure=1&sni=${SNI_DOMAIN}&alpn=h3#HY2-${SERVER_IP}

[SOCKS5 信息]
端口: ${SOCKS_PORT}
用户名: ${SOCKS_USER}
密码: ${SOCKS_PASS}

管理命令:
systemctl status sing-box
systemctl restart sing-box
journalctl -u sing-box -f

配置文件:
${CONFIG_FILE}

EOF
}

detect_ip
install_or_update_singbox
generate_cert
write_config
write_service
check_service
print_result
