# 创建一个临时脚本文件
cat > /tmp/hy2_install.sh << 'SCRIPT'
#!/bin/bash
set -euo pipefail

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
NC='\033[0m'

HOSTNAME="$(hostname)"
HY2_PORT="52015"
SOCKS_PORT="40443"
HOPS_START="50100"
HOPS_END="50200"

echo -e "${GREEN}========================================${NC}"
echo -e "${GREEN}  HY2 + SOCKS5 端口跳跃版安装${NC}"
echo -e "${GREEN}========================================${NC}"

# ========== 安装依赖 (跳过apt update) ==========
echo -e "\n${CYAN}[1/6] 安装依赖...${NC}"
apt install -y -qq curl iptables iptables-persistent netfilter-persistent > /dev/null 2>&1

# ========== 下载 HY2 ==========
echo -e "\n${CYAN}[2/6] 下载 Hysteria2...${NC}"
mkdir -p /opt/hy2
cd /opt/hy2

ARCH=$(uname -m)
case "${ARCH}" in
  x86_64) ARCH_NAME="amd64" ;;
  aarch64|arm64) ARCH_NAME="arm64" ;;
  *) echo -e "${RED}不支持的架构: ${ARCH}${NC}"; exit 1 ;;
esac

HY2_VERSION=$(curl -s https://api.github.com/repos/apernet/hysteria/releases/latest 2>/dev/null | grep -oP '"tag_name":\s*"\K[^"]+' | head -1)
if [ -z "${HY2_VERSION}" ]; then
  echo -e "${YELLOW}获取版本失败，使用 v2.4.2${NC}"
  HY2_VERSION="v2.4.2"
fi

echo -e "  版本: ${HY2_VERSION} (${ARCH_NAME})"
curl -sL "https://github.com/apernet/hysteria/releases/download/${HY2_VERSION}/hysteria-linux-${ARCH_NAME}-${HY2_VERSION}.tar.gz" -o hysteria.tar.gz
tar -xzf hysteria.tar.gz
mv bin/app /usr/local/bin/hy2
chmod +x /usr/local/bin/hy2

# ========== 获取服务器信息 ==========
echo -e "\n${CYAN}[3/6] 获取服务器信息...${NC}"
SERVER_IP=$(curl -s -4 ifconfig.me || curl -s -6 ifconfig.me || hostname -I | awk '{print $1}')
SERVER_REGION=$(curl -s --max-time 5 https://ipinfo.io/city 2>/dev/null || echo "Unknown")
SERVER_COUNTRY=$(curl -s --max-time 5 https://ipinfo.io/country 2>/dev/null || echo "XX")
echo -e "  IP: ${SERVER_IP}"
echo -e "  地区: ${SERVER_REGION}, ${SERVER_COUNTRY}"

# ========== 生成配置 ==========
echo -e "\n${CYAN}[4/6] 生成 HY2 配置...${NC}"

HY2_PASSWORD=$(openssl rand -base64 24 | tr -d '/+' | head -c 16)
SOCKS_USER="soga"
SOCKS_PASS="sogasoga"
SNI_DOMAIN="icloud.cdn-apple.com"

cat > /opt/hy2/config.yaml << EOF
listen: :${HY2_PORT}

tls:
  cert: /opt/hy2/cert.pem
  key: /opt/hy2/key.pem

auth:
  type: password
  password: ${HY2_PASSWORD}

masquerade:
  type: proxy
  proxy:
    url: https://icloud.cdn-apple.com
    rewriteHost: true

bandwidth:
  up: 100 mbps
  down: 100 mbps

quic:
  initRwnd: 10240
  initStreamRwnd: 5120
  maxStreamRwnd: 5120
  maxConnRwnd: 5120
EOF

openssl req -x509 -nodes -newkey ec:<(openssl ecparam -name prime256v1) \
  -keyout /opt/hy2/key.pem -out /opt/hy2/cert.pem \
  -subj "/CN=${SNI_DOMAIN}" -days 3650 2>/dev/null

# ========== 配置 iptables 端口跳跃 ==========
echo -e "\n${CYAN}[5/6] 配置 iptables 端口跳跃...${NC}"

NETWORK_IF=$(ip route get 8.8.8.8 | grep -oP 'dev \K[^ ]+' | head -1)
echo -e "  网卡: ${NETWORK_IF}"
echo -e "  转发规则: ${HOPS_START}-${HOPS_END} → ${HY2_PORT}"

iptables -t nat -F PREROUTING 2>/dev/null || true
iptables -t nat -A PREROUTING -i ${NETWORK_IF} -p udp --dport ${HOPS_START}:${HOPS_END} -j REDIRECT --to-ports ${HY2_PORT}

netfilter-persistent save 2>/dev/null || iptables-save > /etc/iptables/rules.v4

echo -e "  ${GREEN}✓${NC} iptables 规则已配置"

# ========== 创建 systemd 服务 ==========
echo -e "\n${CYAN}[6/6] 创建服务...${NC}"

cat > /etc/systemd/system/hy2-${HY2_PORT}.service << EOF
[Unit]
Description=Hysteria2 Service
After=network.target

[Service]
ExecStart=/usr/local/bin/hy2 server -c /opt/hy2/config.yaml
Restart=on-failure
RestartSec=5
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable hy2-${HY2_PORT} > /dev/null 2>&1
systemctl restart hy2-${HY2_PORT}

# ========== 安装 SOCKS5 (sing-box) ==========
echo -e "\n${CYAN}安装 SOCKS5...${NC}"

mkdir -p /opt/sing-box

SB_VERSION=$(curl -s https://api.github.com/repos/SagerNet/sing-box/releases/latest 2>/dev/null | grep -oP '"tag_name":\s*"\K[^"]+' | head -1 || echo "v1.9.4")
SB_URL="https://github.com/SagerNet/sing-box/releases/download/${SB_VERSION}/sing-box-${SB_VERSION}-linux-${ARCH_NAME}.tar.gz"

curl -sL "${SB_URL}" -o /tmp/sing-box.tar.gz
tar -xzf /tmp/sing-box.tar.gz -C /opt/sing-box --strip-components=1
rm -f /tmp/sing-box.tar.gz
chmod +x /opt/sing-box/sing-box

cat > /opt/sing-box/config.json << EOF
{
  "log": {"level": "info", "output": "/var/log/sing-box.log"},
  "inbounds": [{"type": "socks", "listen": "::", "listen_port": ${SOCKS_PORT}, "users": [{"username": "${SOCKS_USER}", "password": "${SOCKS_PASS}"}]}],
  "outbounds": [{"type": "direct"}]
}
EOF

cat > /etc/systemd/system/sing-box.service << EOF
[Unit]
Description=sing-box SOCKS5 Service
After=network.target
[Service]
ExecStart=/opt/sing-box/sing-box run -c /opt/sing-box/config.json
Restart=on-failure
RestartSec=5
[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable sing-box > /dev/null 2>&1
systemctl restart sing-box

# ========== 输出结果 ==========
sleep 2
HY2_LINK="hysteria2://${HY2_PASSWORD}@${SERVER_IP}:${HY2_PORT},${HOPS_START}-${HOPS_END}?insecure=1&sni=${SNI_DOMAIN}&alpn=h3#${HOSTNAME}-HY2-Hop"

echo ""
echo -e "${GREEN}========================================${NC}"
echo -e "${GREEN}  🎉 安装成功！${NC}"
echo -e "${GREEN}========================================${NC}"
echo ""
echo -e "  主机名: ${HOSTNAME}"
echo -e "  地区: ${SERVER_REGION}, ${SERVER_COUNTRY}"
echo -e "  服务器: ${SERVER_IP}"
echo ""
echo -e "${CYAN}[HY2 端口跳跃]${NC}"
echo -e "  主端口: ${HY2_PORT}"
echo -e "  跳跃范围: ${HOPS_START}-${HOPS_END} (iptables 转发 → ${HY2_PORT})"
echo -e "  密码: ${HY2_PASSWORD}"
echo -e "  SNI: ${SNI_DOMAIN}"
echo ""
echo -e "  链接:"
echo -e "  ${YELLOW}${HY2_LINK}${NC}"
echo ""
echo -e "${CYAN}[SOCKS5]${NC}"
echo -e "  服务器: ${SERVER_IP}"
echo -e "  端口: ${SOCKS_PORT}"
echo -e "  用户名: ${SOCKS_USER}"
echo -e "  密码: ${SOCKS_PASS}"
echo ""
echo -e "${CYAN}管理命令:${NC}"
echo -e "  HY2 状态: systemctl status hy2-${HY2_PORT}"
echo -e "  HY2 日志: journalctl -u hy2-${HY2_PORT} -f"
echo -e "  SOCKS5 状态: systemctl status sing-box"
echo -e "  SOCKS5 日志: journalctl -u sing-box -f"
echo ""
echo -e "${GREEN}========================================${NC}"
SCRIPT

# 运行修改后的脚本
bash /tmp/hy2_install.sh
