port_in_use_by_other() {
  local port="$1"
  local own_name="$2"
  if ss -tulnp 2>/dev/null | grep -q ":${port} "; then
    if ss -tulnp 2>/dev/null | grep ":${port} " | grep -vq "${own_name}"; then
      return 0
    fi
  fi
  return 1
}

stop_conflicting_services() {
  if port_in_use_by_other "${HY2_PORT}" "${HY2_SERVICE}"; then
    echo -e "${YELLOW_BG}[WARNING] Port ${HY2_PORT} is in use. Trying to stop old HY2 service...${NORMAL}"
    systemctl stop "${HY2_SERVICE}" 2>/dev/null || true
    pkill -f "${HY2_DIR}/hy2" 2>/dev/null || true
    sleep 1
  fi

  if port_in_use_by_other "${SOCKS_PORT}" "sing-box"; then
    echo -e "${YELLOW_BG}[WARNING] Port ${SOCKS_PORT} is in use. Trying to stop old sing-box service...${NORMAL}"
    systemctl stop "${SB_SERVICE}" 2>/dev/null || true
    pkill -f "/usr/local/bin/sing-box" 2>/dev/null || true
    sleep 1
  fi
}

start_services() {
  systemctl daemon-reload

  systemctl enable "${HY2_SERVICE}" >/dev/null 2>&1
  systemctl restart "${HY2_SERVICE}"

  systemctl enable "${SB_SERVICE}" >/dev/null 2>&1
  systemctl restart "${SB_SERVICE}"

  sleep 3

  if systemctl is-active --quiet "${HY2_SERVICE}"; then
    echo -e "${GREEN_BG}[Service] ${HY2_SERVICE} started successfully${NORMAL}"
  else
    echo -e "${RED_BG}[ERROR] ${HY2_SERVICE} failed to start${NORMAL}"
    journalctl -u "${HY2_SERVICE}" -n 30 --no-pager || true
    exit 1
  fi

  if systemctl is-active --quiet "${SB_SERVICE}"; then
    echo -e "${GREEN_BG}[Service] ${SB_SERVICE} started successfully${NORMAL}"
  else
    echo -e "${RED_BG}[ERROR] ${SB_SERVICE} failed to start${NORMAL}"
    journalctl -u "${SB_SERVICE}" -n 30 --no-pager || true
    exit 1
  fi
}

generate_client_configs() {
  hy2_url_v4="hysteria2://$(urlencode "${HY2_PASSWORD}")@${ip}:${HY2_PORT}/?insecure=1&sni=${SNI_DOMAIN}&alpn=h3#$(urlencode "${HOSTNAME}-HY2-${HY2_PORT}")"
  hy2_url_compat_v4="hy2://$(urlencode "${HY2_PASSWORD}")@${ip}:${HY2_PORT}/?insecure=1&sni=${SNI_DOMAIN}#$(urlencode "${HOSTNAME}-HY2-${HY2_PORT}")"

  if [[ -n "${ipv6:-}" ]]; then
    hy2_url_v6="hysteria2://$(urlencode "${HY2_PASSWORD}")@[${ipv6}]:${HY2_PORT}/?insecure=1&sni=${SNI_DOMAIN}&alpn=h3#$(urlencode "${HOSTNAME}-HY2-${HY2_PORT}-IPv6")"
    hy2_url_compat_v6="hy2://$(urlencode "${HY2_PASSWORD}")@[${ipv6}]:${HY2_PORT}/?insecure=1&sni=${SNI_DOMAIN}#$(urlencode "${HOSTNAME}-HY2-${HY2_PORT}-IPv6")"
  fi

  json_config=$(cat <<EOF
{
  "type": "hysteria2",
  "tag": "${HOSTNAME}-HY2-${HY2_PORT}",
  "server": "${ip}",
  "server_port": ${HY2_PORT},
  "password": "${HY2_PASSWORD}",
  "tls": {
    "enabled": true,
    "server_name": "${SNI_DOMAIN}",
    "insecure": true,
    "alpn": ["h3"]
