  cat > "${HY2_DIR}/${HY2_PORT}/client-config.txt" <<EOF
========================================
HY2 + SOCKS5 客户端配置
主机名: ${HOSTNAME}
地区: ${REGION}
服务器 IPv4: ${ip}:${HY2_PORT}
$([ -n "${ipv6:-}" ] && echo "服务器 IPv6: [${ipv6}]:${HY2_PORT}")

[HY2]
端口: ${HY2_PORT}
密码: ${HY2_PASSWORD}
SNI: ${SNI_DOMAIN}

[SOCKS5]
服务器: ${ip}
端口: ${SOCKS_PORT}
用户名: ${SOCKS_USER}
密码: ${SOCKS_PASS}

========================================
【Sing-box 配置 IPv4】
${json_config}

【Clash Meta 配置 IPv4】
${clash_config}

========================================
【v2rayN 链接 IPv4】
${hy2_url_v4}

【兼容格式链接 IPv4】
${hy2_url_compat_v4}
========================================
